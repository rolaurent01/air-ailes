---
import ProtectedImage from './ProtectedImage.astro';
import { getGridImageUrl, getGridSrcSet, GRID_SIZES } from '../lib/cloudinary';

interface Props {
  title: string;
  cloudinaryId: string;
  alt: string;
  focalPoint?: string;
  dominantColor?: string;
  index?: number;
}

const {
  title,
  cloudinaryId,
  alt,
  focalPoint = 'auto',
  dominantColor,
  index = 0,
} = Astro.props;
---

<article
  class="photo-card"
  data-cloudinary-id={cloudinaryId}
  data-photo-index={index}
>
  <button class="photo-card__trigger" type="button" aria-label={`Ouvrir ${title} en plein écran`}>
    <ProtectedImage
      cloudinaryId={cloudinaryId}
      alt={alt}
      width={600}
      height={400}
      srcset={getGridSrcSet(cloudinaryId, focalPoint)}
      sizes={GRID_SIZES}
      focalPoint={focalPoint}
      dominantColor={dominantColor}
      aspectRatio="3 / 2"
    />
  </button>
</article>

<style>
  .photo-card {
    position: relative;
    border-radius: 2px;
    overflow: hidden;
    cursor: pointer;
  }

  .photo-card__trigger {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    color: inherit;
    font: inherit;
  }

  .photo-card :global(.protected-image) {
    transition: transform var(--duration-hover, 0.25s) var(--ease-out-expo, ease-out),
                box-shadow var(--duration-hover, 0.25s) var(--ease-out-expo, ease-out);
  }

  .photo-card:hover :global(.protected-image),
  .photo-card:focus-within :global(.protected-image) {
    transform: scale(1.03);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.4);
  }

  @media (prefers-reduced-motion: reduce) {
    .photo-card:hover :global(.protected-image) {
      transform: none;
    }
  }
</style>
