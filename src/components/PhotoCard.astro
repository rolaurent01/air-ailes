---
import ProtectedImage from './ProtectedImage.astro';
import { getOrientedGridImageUrl, getOrientedGridSrcSet, GRID_SIZES } from '../lib/cloudinary';

interface Props {
  title: string;
  cloudinaryId: string;
  alt: string;
  focalPoint?: string;
  dominantColor?: string;
  orientation?: 'landscape' | 'portrait';
  index?: number;
}

const {
  title,
  cloudinaryId,
  alt,
  focalPoint = 'auto',
  dominantColor,
  orientation = 'landscape',
  index = 0,
} = Astro.props;

const aspectRatio = orientation === 'portrait' ? '2 / 3' : '3 / 2';
---

<article
  class:list={['photo-card', `photo-card--${orientation}`]}
  data-cloudinary-id={cloudinaryId}
  data-photo-index={index}
>
  <button class="photo-card__trigger" type="button" aria-label={`Ouvrir ${title} en plein écran`}>
    <ProtectedImage
      cloudinaryId={cloudinaryId}
      alt={alt}
      width={600}
      height={orientation === 'portrait' ? 900 : 400}
      srcset={getOrientedGridSrcSet(cloudinaryId, orientation, focalPoint)}
      sizes={GRID_SIZES}
      focalPoint={focalPoint}
      dominantColor={dominantColor}
      aspectRatio={aspectRatio}
    />
  </button>
</article>

<style>
  .photo-card {
    position: relative;
    border-radius: 3px;
    overflow: hidden;
    cursor: pointer;
    break-inside: avoid;
    margin-bottom: var(--masonry-gap, 1.25rem);
  }

  .photo-card__trigger {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    color: inherit;
    font: inherit;
  }

  .photo-card :global(.protected-image) {
    transition: transform var(--duration-hover, 0.25s) var(--ease-out-expo, ease-out),
                box-shadow var(--duration-hover, 0.25s) var(--ease-out-expo, ease-out),
                filter var(--duration-hover, 0.25s) var(--ease-out-expo, ease-out);
  }

  .photo-card:hover :global(.protected-image),
  .photo-card:focus-within :global(.protected-image) {
    transform: scale(1.02);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
  }

  @media (prefers-reduced-motion: reduce) {
    .photo-card:hover :global(.protected-image) {
      transform: none;
    }
  }
</style>
