---
import PhotoCard from './PhotoCard.astro';

interface PhotoData {
  title: string;
  cloudinary_id: string;
  alt: string;
  focal_point?: string;
  dominant_color?: string;
  display_order: number;
}

interface Props {
  photos: PhotoData[];
  columns?: number;
}

const { photos, columns = 3 } = Astro.props;

const sorted = [...photos].sort((a, b) => a.display_order - b.display_order);
---

<div
  class="gallery"
  id="gallery-grid"
  style={`--gallery-columns: ${columns};`}
>
  {sorted.map((photo, index) => (
    <PhotoCard
      title={photo.title}
      cloudinaryId={photo.cloudinary_id}
      alt={photo.alt}
      focalPoint={photo.focal_point}
      dominantColor={photo.dominant_color}
      index={index}
    />
  ))}
</div>

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(var(--gallery-columns, 3), 1fr);
    gap: var(--space-md, 1.5rem);
    padding-inline: var(--container-padding);
    max-width: var(--container-max);
    margin-inline: auto;
  }

  @media (max-width: 768px) {
    .gallery {
      grid-template-columns: 1fr;
      gap: var(--space-sm, 1rem);
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .gallery {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { ANIMATION_EASING } from '../lib/constants';

  gsap.registerPlugin(ScrollTrigger);

  function initGalleryReveal(): void {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const cards = document.querySelectorAll<HTMLElement>('.photo-card');
    if (!cards.length) return;

    ScrollTrigger.getAll().forEach((t) => t.kill());

    gsap.set(cards, {
      opacity: 0,
      y: 30,
      clipPath: 'inset(12% 0% 12% 0%)',
    });

    cards.forEach((card) => {
      gsap.to(card, {
        opacity: 1,
        y: 0,
        clipPath: 'inset(0% 0% 0% 0%)',
        duration: 0.8,
        ease: ANIMATION_EASING,
        scrollTrigger: {
          trigger: card,
          start: 'top bottom-=10%',
          once: true,
        },
      });
    });
  }

  initGalleryReveal();
  document.addEventListener('astro:page-load', () => {
    initGalleryReveal();
  });
</script>
