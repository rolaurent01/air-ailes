---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  image?: string;
  prevGallery?: { label: string; href: string };
  nextGallery?: { label: string; href: string };
}

const { title, subtitle, description, image, prevGallery, nextGallery } = Astro.props;
---

<BaseLayout title={title} description={description ?? subtitle ?? `Galerie ${title} — Air-Ailes`} image={image}>
  <section class="gallery-header">
    <h1 class="gallery-header__title" id="gallery-title">{title}</h1>
    {subtitle && <p class="gallery-header__subtitle">{subtitle}</p>}
  </section>

  <slot />

  {(prevGallery || nextGallery) && (
    <nav class="gallery-nav" aria-label="Navigation entre galeries">
      {prevGallery ? (
        <a href={prevGallery.href} class="gallery-nav__link gallery-nav__link--prev">
          <span class="gallery-nav__arrow">&larr;</span>
          {prevGallery.label}
        </a>
      ) : <span />}
      {nextGallery ? (
        <a href={nextGallery.href} class="gallery-nav__link gallery-nav__link--next">
          {nextGallery.label}
          <span class="gallery-nav__arrow">&rarr;</span>
        </a>
      ) : <span />}
    </nav>
  )}
</BaseLayout>

<style>
  .gallery-header {
    text-align: center;
    padding-block: var(--space-3xl) var(--space-xl);
    padding-inline: var(--container-padding);
  }

  .gallery-header__title {
    font-size: clamp(2rem, 6vw, var(--font-size-2xl));
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-wider);
    color: var(--color-text-primary);
    margin-bottom: var(--space-sm);
  }

  .gallery-header__subtitle {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    letter-spacing: var(--letter-spacing-wide);
    max-width: 50ch;
    margin-inline: auto;
  }

  .gallery-nav {
    display: flex;
    justify-content: space-between;
    max-width: var(--container-max);
    margin-inline: auto;
    padding: var(--space-2xl) var(--container-padding);
  }

  .gallery-nav__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-uppercase);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    transition: color var(--duration-hover) var(--ease-out-expo);
  }

  .gallery-nav__link:hover {
    color: var(--color-text-primary);
    opacity: 1;
  }

  .gallery-nav__arrow {
    display: inline-block;
    transition: transform var(--duration-hover) var(--ease-out-expo);
  }

  .gallery-nav__link--prev:hover .gallery-nav__arrow {
    transform: translateX(-4px);
  }

  .gallery-nav__link--next:hover .gallery-nav__arrow {
    transform: translateX(4px);
  }
</style>

<script>
  import { animateText } from '../lib/animations/text';

  function initGalleryHeader(): void {
    const title = document.getElementById('gallery-title');
    if (title && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      animateText(title, { mode: 'words', staggerDelay: 0.08 });
    }
  }

  initGalleryHeader();
  document.addEventListener('astro:after-swap', initGalleryHeader);
</script>
