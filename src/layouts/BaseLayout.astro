---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_NAME } from '../lib/constants';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = SITE_NAME,
  description = 'Photographie — Paysage & Portrait',
} = Astro.props;

const pageTitle = title === SITE_NAME ? title : `${title} — ${SITE_NAME}`;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <ClientRouter />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      import { initSmoothScroll, destroySmoothScroll } from '../lib/animations/smooth-scroll';

      // Initialisation Lenis
      initSmoothScroll();

      // Réinitialiser après navigation (View Transitions)
      document.addEventListener('astro:after-swap', () => {
        destroySmoothScroll();
        initSmoothScroll();
      });
    </script>
  </body>
</html>
