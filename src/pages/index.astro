---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_NAME, SITE_DESCRIPTION } from '../lib/constants';
---

<BaseLayout>
  <section class="hero">
    <h1 class="hero__title" id="hero-title">{SITE_NAME}</h1>
    <p class="hero__subtitle" id="hero-subtitle">{SITE_DESCRIPTION}</p>
    <div class="hero__scroll-indicator" id="scroll-indicator">
      <span class="hero__scroll-line"></span>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    text-align: center;
    padding-inline: var(--space-md);
    position: relative;
  }

  .hero__title {
    font-size: var(--font-size-hero);
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-wider);
    color: var(--color-text-primary);
    margin-bottom: var(--space-md);
  }

  .hero__subtitle {
    font-size: clamp(var(--font-size-sm), 2.5vw, var(--font-size-md));
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-uppercase);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    opacity: 0;
    transform: translateY(20px);
  }

  .hero__scroll-indicator {
    position: absolute;
    bottom: var(--space-xl);
    display: flex;
    justify-content: center;
    opacity: 0;
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 48px;
    background: linear-gradient(
      to bottom,
      var(--color-text-secondary),
      transparent
    );
    animation: scroll-pulse 2s var(--ease-out-expo) infinite;
  }

  @keyframes scroll-pulse {
    0% {
      transform: scaleY(0);
      transform-origin: top;
      opacity: 0;
    }
    30% {
      opacity: 1;
    }
    100% {
      transform: scaleY(1);
      transform-origin: top;
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__scroll-line {
      animation: none;
      opacity: 0.5;
    }
  }
</style>

<script>
  import { animateText } from '../lib/animations/text';
  import { gsap } from 'gsap';
  import { ANIMATION_EASING } from '../lib/constants';

  function initHero(): void {
    const title = document.getElementById('hero-title');
    const subtitle = document.getElementById('hero-subtitle');
    const scrollIndicator = document.getElementById('scroll-indicator');

    if (!title) return;

    // Animation titre lettre par lettre
    animateText(title, { mode: 'letters', staggerDelay: 0.05 });

    // Animation sous-titre en fade-up après le titre
    if (subtitle && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.to(subtitle, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        delay: 0.8,
        ease: ANIMATION_EASING,
      });
    } else if (subtitle) {
      subtitle.style.opacity = '1';
      subtitle.style.transform = 'none';
    }

    // Animation scroll indicator
    if (scrollIndicator && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.to(scrollIndicator, {
        opacity: 1,
        duration: 0.6,
        delay: 1.4,
        ease: ANIMATION_EASING,
      });
    } else if (scrollIndicator) {
      scrollIndicator.style.opacity = '1';
    }
  }

  initHero();
  document.addEventListener('astro:after-swap', initHero);
</script>
