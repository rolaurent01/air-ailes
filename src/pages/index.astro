---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProtectedImage from '../components/ProtectedImage.astro';
import Lightbox from '../components/Lightbox.astro';
import { getHeroSrcSet, HERO_SIZES } from '../lib/cloudinary';
import { SITE_NAME, SITE_DESCRIPTION } from '../lib/constants';

const allPhotos = await getCollection('galeries');
const sorted = allPhotos.sort((a, b) => a.data.display_order - b.data.display_order);

const heroPhoto = sorted[0];

// 4 hand-picked showcase photos (in order)
const showcaseIds = [
  'paysage/img-1066',
  'paysage/dsc06881',
  'paysage/dsc06262',
  'paysage/dsc02293',
];
const allPhotosMap = new Map(allPhotos.map((p) => [p.data.cloudinary_id, p]));
const showcasePhotos = showcaseIds
  .map((id) => allPhotosMap.get(id))
  .filter((p): p is NonNullable<typeof p> => p != null);

const blogEntries = await getCollection('blog');
const recentPosts = blogEntries
  .filter((p) => p.data.published)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

const lightboxPhotos = showcasePhotos.map((p) => ({
  cloudinary_id: p.data.cloudinary_id,
  title: p.data.title,
  alt: p.data.alt,
  location: p.data.location,
  date: p.data.date?.toISOString(),
}));
---

<BaseLayout
  description="Photographie de paysage et macro — découvrez l'univers visuel d'Air-Ailes."
  image={heroPhoto.data.cloudinary_id}
>
  <!-- Hero -->
  <section class="hero" id="hero">
    <div class="hero__bg" id="hero-bg">
      <ProtectedImage
        cloudinaryId={heroPhoto.data.cloudinary_id}
        alt={heroPhoto.data.alt}
        width={2000}
        height={1333}
        srcset={getHeroSrcSet(heroPhoto.data.cloudinary_id, heroPhoto.data.focal_point)}
        sizes={HERO_SIZES}
        focalPoint={heroPhoto.data.focal_point}
        eager={true}
        fetchPriority={true}
        dominantColor={heroPhoto.data.dominant_color}
      />
    </div>
    <div class="hero__gradient"></div>
    <div class="hero__content">
      <h1 class="hero__title" id="hero-title">{SITE_NAME}</h1>
      <p class="hero__subtitle" id="hero-subtitle">{SITE_DESCRIPTION}</p>
    </div>
    <div class="hero__scroll-indicator" id="scroll-indicator">
      <span class="hero__scroll-line"></span>
    </div>
  </section>

  <!-- Showcase — 4 photos plein écran, une par une -->
  <section class="showcase" id="showcase">
    {showcasePhotos.map((photo, index) => (
      <div
        class="showcase__slide"
        data-showcase-index={index}
        data-cloudinary-id={photo.data.cloudinary_id}
        data-photo-index={index}
      >
        <div class="showcase__image-wrap">
          <ProtectedImage
            cloudinaryId={photo.data.cloudinary_id}
            alt={photo.data.alt}
            width={2000}
            height={1333}
            srcset={getHeroSrcSet(photo.data.cloudinary_id, photo.data.focal_point)}
            sizes={HERO_SIZES}
            focalPoint={photo.data.focal_point}
            dominantColor={photo.data.dominant_color}
          />
        </div>
      </div>
    ))}

    <div class="showcase__cta">
      <a href="/galeries" class="showcase__link">
        Découvrir toute la galerie
        <span class="showcase__arrow">&rarr;</span>
      </a>
    </div>
  </section>

  <Lightbox photos={lightboxPhotos} />

  <hr class="section-separator" />

  <!-- Blog / Formation -->
  {recentPosts.length > 0 && (
    <section class="blog-preview" id="blog-preview">
      <div class="blog-preview__header">
        <h2 class="blog-preview__title" id="blog-title">Formation Photo</h2>
      </div>
      <div class="blog-preview__grid">
        {recentPosts.map((post) => (
          <a href={`/blog/${post.data.slug}`} class="blog-card-link">
            <article class="blog-card">
              <div class="blog-card__image">
                <img src={post.data.cover_svg} alt={post.data.title} width="600" height="400" loading="lazy" />
              </div>
              <div class="blog-card__content">
                <time class="blog-card__date" datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('fr-FR', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
                <h3 class="blog-card__heading">{post.data.title}</h3>
                <p class="blog-card__excerpt">{post.data.excerpt}</p>
              </div>
            </article>
          </a>
        ))}
      </div>
      <div class="blog-preview__cta">
        <a href="/blog" class="showcase__link">
          Voir la formation
          <span class="showcase__arrow">&rarr;</span>
        </a>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* --- Hero --- */
  .hero {
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    will-change: transform;
  }

  .hero__gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(5, 5, 5, 0) 0%, rgba(5, 5, 5, 0.3) 70%),
      linear-gradient(
        to bottom,
        rgba(5, 5, 5, 0.15) 0%,
        rgba(5, 5, 5, 0.05) 40%,
        rgba(5, 5, 5, 0.4) 75%,
        rgba(5, 5, 5, 0.85) 100%
      );
  }

  .hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding-inline: var(--space-md);
  }

  .hero__title {
    font-size: var(--font-size-hero);
    letter-spacing: var(--letter-spacing-wider);
    color: var(--color-text-primary);
    margin-bottom: var(--space-md);
  }

  .hero__subtitle {
    font-size: clamp(var(--font-size-sm), 2.5vw, var(--font-size-md));
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-uppercase);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    opacity: 0;
    transform: translateY(20px);
  }

  .hero__scroll-indicator {
    position: absolute;
    bottom: var(--space-xl);
    z-index: 2;
    display: flex;
    justify-content: center;
    opacity: 0;
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--color-text-secondary), transparent);
    animation: scroll-pulse 2s var(--ease-out-expo) infinite;
  }

  @keyframes scroll-pulse {
    0% { transform: scaleY(0); transform-origin: top; opacity: 0; }
    30% { opacity: 1; }
    100% { transform: scaleY(1); transform-origin: top; opacity: 0; }
  }

  /* ======================================================
     SHOWCASE — cinematic full-screen photo sequence
     ====================================================== */
  .showcase {
    position: relative;
  }

  .showcase__slide {
    position: relative;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .showcase__image-wrap {
    position: absolute;
    inset: 0;
    will-change: transform, clip-path;
    /* Start hidden — GSAP animates these */
    clip-path: inset(15% 15% 15% 15%);
    transform: scale(1.15);
  }

  .showcase__image-wrap :global(.protected-image) {
    width: 100%;
    height: 100%;
  }

  .showcase__image-wrap :global(.protected-image__main),
  .showcase__image-wrap :global(.protected-image__lqip) {
    object-fit: cover;
  }


  .showcase__cta {
    text-align: center;
    padding-block: var(--space-2xl);
  }

  .showcase__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-uppercase);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    transition: color var(--duration-hover) var(--ease-out-expo);
  }

  .showcase__link:hover {
    color: var(--color-text-primary);
    opacity: 1;
  }

  .showcase__arrow {
    display: inline-block;
    transition: transform var(--duration-hover) var(--ease-out-expo);
  }

  .showcase__link:hover .showcase__arrow {
    transform: translateX(4px);
  }

  /* --- Blog preview --- */
  .blog-preview {
    padding-block: var(--space-2xl) var(--space-3xl);
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .blog-preview__header {
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .blog-preview__title {
    font-size: var(--font-size-2xl);
    letter-spacing: var(--letter-spacing-wider);
    color: var(--color-text-primary);
  }

  .blog-preview__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 768px) {
    .blog-preview__grid {
      grid-template-columns: 1fr;
    }
  }

  .blog-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    opacity: 1;
  }

  .blog-card-link:hover {
    opacity: 1;
  }

  .blog-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .blog-card {
      grid-template-columns: 1fr;
    }
  }

  .blog-card__image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 2px;
    transition: transform var(--duration-slow) var(--ease-out-expo);
  }

  .blog-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .blog-card:hover .blog-card__image {
    transform: scale(1.03);
  }

  .blog-card__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-xs);
  }

  .blog-card__date {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
  }

  .blog-card__heading {
    font-size: var(--font-size-lg);
    letter-spacing: var(--letter-spacing-wide);
    color: var(--color-text-primary);
  }

  .blog-card__excerpt {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
  }

  .blog-preview__cta {
    text-align: center;
    margin-top: var(--space-xl);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__scroll-line {
      animation: none;
      opacity: 0.5;
    }
    .blog-card:hover .blog-card__image {
      transform: none;
    }
    .showcase__image-wrap {
      clip-path: none;
      transform: none;
    }
  }
</style>

<script>
  import { animateText } from '../lib/animations/text';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { ANIMATION_EASING } from '../lib/constants';

  gsap.registerPlugin(ScrollTrigger);

  function initHome(): void {
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const title = document.getElementById('hero-title');
    const subtitle = document.getElementById('hero-subtitle');
    const scrollIndicator = document.getElementById('scroll-indicator');
    const heroBg = document.getElementById('hero-bg');
    const blogTitle = document.getElementById('blog-title');

    if (!title) return;

    ScrollTrigger.getAll().forEach((t) => t.kill());

    // Titre lettre par lettre
    animateText(title, { mode: 'letters', staggerDelay: 0.05 });

    if (!reducedMotion) {
      // Sous-titre fade-up
      if (subtitle) {
        gsap.to(subtitle, {
          opacity: 1, y: 0, duration: 0.6, delay: 0.8, ease: ANIMATION_EASING,
        });
      }

      // Scroll indicator
      if (scrollIndicator) {
        gsap.to(scrollIndicator, {
          opacity: 1, duration: 0.6, delay: 1.4, ease: ANIMATION_EASING,
        });
      }

      // Parallax hero
      if (heroBg) {
        gsap.to(heroBg, {
          yPercent: 20,
          ease: 'none',
          scrollTrigger: {
            trigger: '#hero',
            start: 'top top',
            end: 'bottom top',
            scrub: true,
          },
        });
      }

      // ===== SHOWCASE — cinematic full-screen photo reveals =====
      const slides = document.querySelectorAll<HTMLElement>('.showcase__slide');

      slides.forEach((slide) => {
        const imageWrap = slide.querySelector('.showcase__image-wrap');
        if (!imageWrap) return;

        gsap.timeline({
          scrollTrigger: {
            trigger: slide,
            start: 'top top',
            end: '+=100%',
            pin: true,
            scrub: 0.8,
          },
        }).fromTo(imageWrap,
          { clipPath: 'inset(15% 15% 15% 15%)', scale: 1.15 },
          { clipPath: 'inset(0% 0% 0% 0%)', scale: 1, duration: 1, ease: 'power2.out' },
          0
        );
      });

      // Blog title reveal
      if (blogTitle) {
        animateText(blogTitle, {
          mode: 'words',
          staggerDelay: 0.08,
          scrollTrigger: { trigger: blogTitle, start: 'top bottom-=15%' },
        });
      }

      // Blog cards fade-up
      const blogCards = document.querySelectorAll('.blog-card');
      gsap.set(blogCards, { opacity: 0, y: 30 });
      blogCards.forEach((card, i) => {
        gsap.to(card, {
          opacity: 1, y: 0, duration: 0.6, delay: i * 0.1,
          ease: ANIMATION_EASING,
          scrollTrigger: {
            trigger: card,
            start: 'top bottom-=10%',
            once: true,
          },
        });
      });
    } else {
      // Reduced motion : tout visible immédiatement
      if (subtitle) { subtitle.style.opacity = '1'; subtitle.style.transform = 'none'; }
      if (scrollIndicator) { scrollIndicator.style.opacity = '1'; }
    }
  }

  initHome();
  document.addEventListener('astro:page-load', () => {
    initHome();
  });
</script>
