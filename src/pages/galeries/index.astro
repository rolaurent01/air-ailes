---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhotoCard from '../../components/PhotoCard.astro';
import Lightbox from '../../components/Lightbox.astro';

const allPhotos = await getCollection('galeries');
const photos = allPhotos.sort((a, b) => a.data.display_order - b.data.display_order);

const lightboxPhotos = photos.map((p) => ({
  cloudinary_id: p.data.cloudinary_id,
  title: p.data.title,
  alt: p.data.alt,
  location: p.data.location,
  date: p.data.date?.toISOString(),
}));
---

<BaseLayout
  title="Galerie"
  description="Portfolio photographique Air-Ailes — paysages, nature, macro et détails."
  image={photos[0]?.data.cloudinary_id}
>
  <section class="gallery-page">
    <div class="gallery-page__header">
      <h1 class="gallery-page__title" id="gallery-title">Galerie</h1>
      <p class="gallery-page__count">{photos.length} photographies</p>
    </div>

    <div class="gallery-page__grid">
      {photos.map((photo, index) => (
        <PhotoCard
          title={photo.data.title}
          cloudinaryId={photo.data.cloudinary_id}
          alt={photo.data.alt}
          orientation={photo.data.orientation}
          gridSize={photo.data.grid_size}
          dominantColor={photo.data.dominant_color}
          index={index}
        />
      ))}
    </div>
  </section>

  <Lightbox photos={lightboxPhotos} />
</BaseLayout>

<style>
  .gallery-page {
    padding-block: var(--space-3xl) var(--space-2xl);
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .gallery-page__header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .gallery-page__title {
    font-size: clamp(2rem, 6vw, var(--font-size-2xl));
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-wider);
    color: var(--color-text-primary);
    margin-bottom: var(--space-xs);
  }

  .gallery-page__count {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    letter-spacing: var(--letter-spacing-uppercase);
    text-transform: uppercase;
    opacity: 0.6;
  }

  .gallery-page__grid {
    column-count: 2;
    column-gap: 28px;
  }

  @media (max-width: 768px) {
    .gallery-page__grid {
      column-count: 1;
      column-gap: 20px;
    }
  }

  /* Override PhotoCard gap for this page */
  .gallery-page__grid :global(.photo-card) {
    margin-bottom: 28px;
  }

  @media (max-width: 768px) {
    .gallery-page__grid :global(.photo-card) {
      margin-bottom: 20px;
    }
  }
</style>

<script>
  import { animateText } from '../../lib/animations/text';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { ANIMATION_EASING } from '../../lib/constants';

  gsap.registerPlugin(ScrollTrigger);

  function initGalleryPage(): void {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const title = document.getElementById('gallery-title');
    if (!title) return;

    ScrollTrigger.getAll().forEach((t) => t.kill());
    animateText(title, { mode: 'letters', staggerDelay: 0.05 });

    const cards = document.querySelectorAll<HTMLElement>('.photo-card');
    gsap.set(cards, { opacity: 0, y: 30, clipPath: 'inset(8% 0% 8% 0%)' });
    cards.forEach((card) => {
      gsap.to(card, {
        opacity: 1, y: 0, clipPath: 'inset(0% 0% 0% 0%)',
        duration: 0.8,
        ease: ANIMATION_EASING,
        scrollTrigger: { trigger: card, start: 'top bottom-=5%', once: true },
      });
    });
  }

  initGalleryPage();
  document.addEventListener('astro:page-load', () => {
    initGalleryPage();
  });
</script>
