---
import { getCollection } from 'astro:content';
import GalleryLayout from '../../layouts/GalleryLayout.astro';
import Gallery from '../../components/Gallery.astro';
import Lightbox from '../../components/Lightbox.astro';

const allPhotos = await getCollection('galeries');
const photos = allPhotos
  .filter((p) => p.data.gallery === 'paysage')
  .sort((a, b) => a.data.display_order - b.data.display_order);

const lightboxPhotos = photos.map((p) => ({
  cloudinary_id: p.data.cloudinary_id,
  title: p.data.title,
  alt: p.data.alt,
  location: p.data.location,
  date: p.data.date?.toISOString(),
}));

const galleryPhotos = photos.map((p) => p.data);
---

<GalleryLayout
  title="Paysage & Nature"
  subtitle="Montagnes, lacs, forêts — la nature dans toute sa splendeur"
  description="Galerie paysage Air-Ailes — montagnes, lacs, forêts et lumières naturelles capturés au fil des saisons."
  image={photos[0]?.data.cloudinary_id}
  prevGallery={undefined}
  nextGallery={{ label: 'Portrait', href: '/galeries/portrait' }}
>
  <Gallery photos={galleryPhotos} columns={3} />
  <Lightbox photos={lightboxPhotos} />
</GalleryLayout>
