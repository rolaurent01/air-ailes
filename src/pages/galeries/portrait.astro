---
import { getCollection } from 'astro:content';
import GalleryLayout from '../../layouts/GalleryLayout.astro';
import Gallery from '../../components/Gallery.astro';
import Lightbox from '../../components/Lightbox.astro';

const allPhotos = await getCollection('galeries');
const photos = allPhotos
  .filter((p) => p.data.gallery === 'portrait')
  .sort((a, b) => a.data.display_order - b.data.display_order);

const lightboxPhotos = photos.map((p) => ({
  cloudinary_id: p.data.cloudinary_id,
  title: p.data.title,
  alt: p.data.alt,
  location: p.data.location,
  date: p.data.date?.toISOString(),
}));

const galleryPhotos = photos.map((p) => p.data);
---

<GalleryLayout
  title="Portrait & Mode"
  subtitle="Regards, expressions, lumière — l'humain au centre de l'image"
  prevGallery={{ label: 'Paysage', href: '/galeries/paysage' }}
  nextGallery={undefined}
>
  <Gallery photos={galleryPhotos} columns={3} />
  <Lightbox photos={lightboxPhotos} />
</GalleryLayout>
