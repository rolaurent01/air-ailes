---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SOCIAL_LINKS, CLOUDINARY_CLOUD_NAME } from '../lib/constants';

const CLOUD_VIDEO_BASE = `https://res.cloudinary.com/${CLOUDINARY_CLOUD_NAME}/video/upload`;

const videos = [
  { id: 'videos/couche-de-soleil', title: 'Coucher de soleil', orientation: 'landscape' as const },
  { id: 'videos/alpe-dhuez-dec-25', title: "Alpe d'Huez", orientation: 'portrait' as const },
  { id: 'videos/ah-25', title: 'Survol aérien', orientation: 'portrait' as const },
  { id: 'videos/morning-ah-1', title: 'Lever de soleil', orientation: 'portrait' as const },
  { id: 'videos/morning-ah-3', title: 'Brume matinale', orientation: 'portrait' as const },
  { id: 'videos/ma-video', title: 'Vol au dessus des crêtes', orientation: 'portrait' as const },
  { id: 'videos/ma-video-2', title: 'Panorama hivernal', orientation: 'portrait' as const },
];

function getVideoUrl(cloudinaryId: string): string {
  return `${CLOUD_VIDEO_BASE}/q_auto/${cloudinaryId}.mp4`;
}

function getPosterUrl(cloudinaryId: string): string {
  return `${CLOUD_VIDEO_BASE}/so_0,w_800,f_jpg,q_auto/${cloudinaryId}.jpg`;
}
---

<BaseLayout
  title="Envol — Vues aériennes"
  description="Survols en drone et prises de vue aériennes des Alpes — Air-Ailes."
>
  <section class="videos-page">
    <div class="videos-page__header">
      <h1 class="videos-page__title" id="videos-title">Envol</h1>
      <p class="videos-page__subtitle">Survols en drone et prises de vue aériennes</p>
    </div>

    {videos.map((video, index) => (
      <div
        class:list={['video-slide', { 'video-slide--first': index === 0 }]}
        data-video-src={getVideoUrl(video.id)}
        data-video-orientation={video.orientation}
      >
        <div class="video-slide__wrap">
          <video
            class="video-slide__video"
            poster={getPosterUrl(video.id)}
            preload={index === 0 ? 'auto' : 'none'}
            muted
            loop
            playsinline
            src={index === 0 ? getVideoUrl(video.id) : undefined}
          />
        </div>
        <div class="video-slide__meta">
          <span class="video-slide__name">{video.title}</span>
        </div>
      </div>
    ))}

    <div class="videos-page__cta">
      <a href={SOCIAL_LINKS.instagram} target="_blank" rel="noopener noreferrer" class="videos-page__link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
          <circle cx="12" cy="12" r="5" />
          <circle cx="17.5" cy="6.5" r="1" />
        </svg>
        Plus de vidéos sur Instagram
        <span class="videos-page__arrow">&rarr;</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .videos-page__header {
    padding-block: var(--space-3xl) var(--space-xl);
    text-align: center;
  }

  .videos-page__title {
    font-size: clamp(2rem, 6vw, var(--font-size-2xl));
    letter-spacing: var(--letter-spacing-wider);
    color: var(--color-text-primary);
    margin-bottom: var(--space-sm);
  }

  .videos-page__subtitle {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-light);
    color: var(--color-text-secondary);
    letter-spacing: var(--letter-spacing-wide);
  }

  /* ====== Video Slides ====== */
  .video-slide {
    position: relative;
    height: 100vh;
    overflow: hidden;
  }

  .video-slide__wrap {
    position: absolute;
    inset: 0;
    background-color: var(--color-bg-primary);
    /* Default: hidden with clip-path for scroll-reveal slides */
    clip-path: inset(12% 12% 12% 12%);
    transform: scale(1.1);
  }

  /* First slide: no clip-path, just opacity fade */
  .video-slide--first .video-slide__wrap {
    clip-path: none;
    transform: none;
    opacity: 0;
    transition: opacity 1.2s var(--ease-out-expo);
  }

  .video-slide--first .video-slide__wrap.is-playing {
    opacity: 1;
  }

  .video-slide__video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-slide[data-video-orientation="portrait"] .video-slide__video {
    object-fit: contain;
    background-color: var(--color-bg-primary);
  }

  .video-slide__meta {
    position: absolute;
    bottom: var(--space-xl);
    left: 0;
    right: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    opacity: 0;
    pointer-events: none;
  }

  .video-slide__name {
    font-family: var(--font-family);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-wide);
    color: var(--color-text-primary);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.5);
  }

  .video-slide::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 30%;
    z-index: 1;
    background: linear-gradient(to top, rgba(5, 5, 5, 0.5) 0%, transparent 100%);
    pointer-events: none;
  }

  /* ====== CTA ====== */
  .videos-page__cta {
    text-align: center;
    padding-block: var(--space-2xl) var(--space-3xl);
  }

  .videos-page__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-uppercase);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    transition: color var(--duration-hover) var(--ease-out-expo);
  }

  .videos-page__link:hover {
    color: var(--color-text-primary);
    opacity: 1;
  }

  .videos-page__arrow {
    display: inline-block;
    transition: transform var(--duration-hover) var(--ease-out-expo);
  }

  .videos-page__link:hover .videos-page__arrow {
    transform: translateX(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .video-slide__wrap {
      clip-path: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
    .video-slide__meta {
      opacity: 1;
    }
  }
</style>

<script>
  import { animateText } from '../lib/animations/text';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { ANIMATION_EASING } from '../lib/constants';

  gsap.registerPlugin(ScrollTrigger);

  function initVideosPage(): void {
    const title = document.getElementById('videos-title');
    if (!title) return;

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    ScrollTrigger.getAll().forEach((t) => t.kill());

    if (!reducedMotion) {
      animateText(title, { mode: 'letters', staggerDelay: 0.05 });
    }

    const slides = document.querySelectorAll<HTMLElement>('.video-slide');

    slides.forEach((slide, i) => {
      const wrap = slide.querySelector<HTMLElement>('.video-slide__wrap');
      const video = slide.querySelector<HTMLVideoElement>('.video-slide__video');
      const meta = slide.querySelector<HTMLElement>('.video-slide__meta');
      const dataSrc = slide.dataset.videoSrc;
      const isFirst = i === 0;

      if (!wrap || !video) return;

      // --- Helper: load video src if not already loaded ---
      function ensureLoaded(): void {
        if (!video!.getAttribute('src') && dataSrc) {
          video!.src = dataSrc;
          video!.load();
        }
      }

      // --- Helper: play video safely ---
      function playVideo(): void {
        ensureLoaded();
        video!.play().catch(() => {});
      }

      // ============================================
      // FIRST VIDEO: auto-load, fade in when ready
      // ============================================
      if (isFirst) {
        // src is already set in HTML for the first video
        video.addEventListener('canplay', () => {
          wrap!.classList.add('is-playing');
          video!.play().catch(() => {});
          if (meta && !reducedMotion) {
            gsap.to(meta, { opacity: 1, duration: 0.6, delay: 0.8, ease: ANIMATION_EASING });
          }
        }, { once: true });

        // Pause when off-screen
        if (!reducedMotion) {
          ScrollTrigger.create({
            trigger: slide,
            start: 'top bottom',
            end: 'bottom top',
            onLeave: () => video.pause(),
            onEnterBack: () => video.play().catch(() => {}),
            onLeaveBack: () => video.pause(),
          });
        }
        return;
      }

      // ============================================
      // OTHER VIDEOS: scroll reveal + autoplay
      // ============================================
      if (reducedMotion) {
        // Simple intersection-based load & play
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                playVideo();
              } else {
                video.pause();
              }
            });
          },
          { threshold: 0.3 }
        );
        observer.observe(slide);
        return;
      }

      // GSAP: pin slide, reveal clip-path, then play
      let hasPlayed = false;

      gsap.timeline({
        scrollTrigger: {
          trigger: slide,
          start: 'top top',
          end: '+=100%',
          pin: true,
          scrub: 0.6,
          onEnter: () => ensureLoaded(),
          onUpdate: (self) => {
            // Play video once reveal is ~30% complete
            if (self.progress > 0.3 && !hasPlayed) {
              hasPlayed = true;
              playVideo();
              if (meta) {
                gsap.to(meta, { opacity: 1, duration: 0.4, ease: ANIMATION_EASING });
              }
            }
          },
          onLeave: () => video.pause(),
          onLeaveBack: () => { video.pause(); hasPlayed = false; },
          onEnterBack: () => {
            playVideo();
            hasPlayed = true;
            if (meta) gsap.set(meta, { opacity: 1 });
          },
        },
      }).fromTo(wrap,
        { clipPath: 'inset(12% 12% 12% 12%)', scale: 1.1 },
        { clipPath: 'inset(0% 0% 0% 0%)', scale: 1, duration: 1, ease: 'power2.out' },
      );
    });
  }

  initVideosPage();
  document.addEventListener('astro:page-load', initVideosPage);
</script>
