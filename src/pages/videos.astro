---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import { SOCIAL_LINKS } from '../lib/constants';

const allVideos = await getCollection('videos');
const videos = allVideos.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Vidéos"
  description="Coulisses, créations et moments capturés en vidéo — retrouvez Air-Ailes sur Instagram."
>
  <section class="videos-page">
    <div class="videos-page__header">
      <h1 class="videos-page__title" id="videos-title">Vidéos</h1>
      <p class="videos-page__subtitle">Retrouvez mes coulisses et créations sur Instagram</p>
    </div>

    <div class="videos-page__grid">
      {videos.map((video) => (
        <VideoEmbed
          platform={video.data.platform}
          embedUrl={video.data.embed_url}
          title={video.data.title}
          description={video.data.description}
        />
      ))}
    </div>

    <div class="videos-page__socials">
      <a href={SOCIAL_LINKS.instagram} target="_blank" rel="noopener noreferrer" class="videos-page__social-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
          <circle cx="12" cy="12" r="5" />
          <circle cx="17.5" cy="6.5" r="1" />
        </svg>
        Instagram
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .videos-page {
    padding-block: var(--space-3xl) var(--space-2xl);
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .videos-page__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .videos-page__title {
    font-size: clamp(2rem, 6vw, var(--font-size-2xl));
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-wider);
    color: var(--color-text-primary);
    margin-bottom: var(--space-sm);
  }

  .videos-page__subtitle {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    letter-spacing: var(--letter-spacing-wide);
  }

  .videos-page__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 1024px) {
    .videos-page__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .videos-page__grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin-inline: auto;
    }
  }

  .videos-page__socials {
    display: flex;
    justify-content: center;
    gap: var(--space-lg);
    margin-top: var(--space-2xl);
  }

  .videos-page__social-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 24px;
    border: 1px solid var(--color-border-subtle);
    border-radius: 2px;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-uppercase);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    transition: color var(--duration-hover) var(--ease-out-expo),
                border-color var(--duration-hover) var(--ease-out-expo);
  }

  .videos-page__social-link:hover {
    color: var(--color-text-primary);
    border-color: rgba(240, 237, 232, 0.2);
    opacity: 1;
  }
</style>

<script>
  import { animateText } from '../lib/animations/text';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { ANIMATION_EASING } from '../lib/constants';

  gsap.registerPlugin(ScrollTrigger);

  function initVideosPage(): void {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const title = document.getElementById('videos-title');
    if (!title) return;

    ScrollTrigger.getAll().forEach((t) => t.kill());
    animateText(title, { mode: 'letters', staggerDelay: 0.05 });

    const embeds = document.querySelectorAll('.video-embed');
    gsap.set(embeds, { opacity: 0, y: 30, clipPath: 'inset(8% 0% 8% 0%)' });
    embeds.forEach((embed) => {
      gsap.to(embed, {
        opacity: 1, y: 0, clipPath: 'inset(0% 0% 0% 0%)',
        duration: 0.8,
        ease: ANIMATION_EASING,
        scrollTrigger: { trigger: embed, start: 'top bottom-=10%', once: true },
      });
    });
  }

  initVideosPage();
  document.addEventListener('astro:page-load', () => {
    initVideosPage();
  });
</script>
